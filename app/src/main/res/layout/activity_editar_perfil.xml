<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gris_claro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/naranja"
        android:padding="14dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco"
            android:textSize="18sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editar Perfil"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto de perfil"
            android:textColor="@color/negro"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtInicialPerfil"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:textColor="@color/blanco"
                android:textSize="36sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgFotoPerfil"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Foto de perfil actual" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnSubirFoto"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:background="@drawable/bg_boton"
                android:text="Subir foto"
                android:textColor="@color/blanco"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEliminarFoto"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_boton_oscuro"
                android:text="Eliminar foto"
                android:textColor="@color/blanco"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textColor="@color/negro"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
                android:textColorHint="@color/texto_secundario"
            android:id="@+id/edtNombre"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_campo"
            android:hint="Tu nombre"
            android:inputType="textPersonName"
            android:padding="14dp"
            android:textColor="@color/negro"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correo"
            android:textColor="@color/negro"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtCorreo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_tarjeta"
            android:padding="14dp"
            android:textColor="@color/gris"
            android:textSize="15sp"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_boton"
            android:text="Guardar cambios"
            android:textColor="@color/blanco"
            android:textStyle="bold" />

        <!-- Cambio de contrasena: la clave se guarda cifrada (RNF-03) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/linea"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cambiar contrasena"
            android:textColor="@color/negro"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <EditText
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_principal"
            android:id="@+id/edtClaveActual"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_campo"
            android:hint="Contrasena actual"
            android:inputType="textPassword"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="10dp" />

        <EditText
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_principal"
            android:id="@+id/edtClaveNueva"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_campo"
            android:hint="Nueva contrasena (minimo 6 caracteres)"
            android:inputType="textPassword"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="10dp" />

        <EditText
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_principal"
            android:id="@+id/edtClaveConfirmar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_campo"
            android:hint="Confirmar nueva contrasena"
            android:inputType="textPassword"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnCambiarClave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_boton_oscuro"
            android:text="Actualizar contrasena"
            android:textColor="@color/blanco"
            android:textStyle="bold" />
    </LinearLayout>
    </ScrollView>
</LinearLayout>
