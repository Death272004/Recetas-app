<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_tarjeta"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtAvatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textColor="@color/texto_principal"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtRolBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="correo@ejemplo.com"
                android:textColor="@color/texto_secundario"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtEstadoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activo"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtFechas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registro: --  |  Ultimo acceso: --"
        android:textColor="@color/texto_secundario"
        android:textSize="11sp"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnCambiarRol"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Rol"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/azul"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnCambiarEstado"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Estado"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/amarillo"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnResetClave"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Reset clave"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/gris"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Eliminar"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/rojo" />
    </LinearLayout>
</LinearLayout>
