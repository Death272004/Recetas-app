<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/naranja"
        android:padding="14dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco"
            android:textSize="18sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Recetas para ti"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtFiltro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:text="Resultados"
        android:textColor="@color/gris"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnBuscarYouTube"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_boton_oscuro"
        android:text="▶  Buscar videos en YouTube"
        android:textColor="@color/blanco"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp" />

    <TextView
        android:id="@+id/txtVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:gravity="center"
        android:text="Con los ingredientes disponibles no puedes preparar ninguna receta."
        android:textColor="@color/gris"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerResultados"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="14dp"
        android:clipToPadding="false" />
</LinearLayout>
