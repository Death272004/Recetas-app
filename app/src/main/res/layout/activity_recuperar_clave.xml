<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/naranja"
        android:padding="14dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco"
            android:textSize="18sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Recuperar contrasena"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- PASO 1: identificar la cuenta por su correo -->
            <LinearLayout
                android:id="@+id/panelPaso1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paso 1: identifica tu cuenta"
                    android:textColor="@color/negro"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Escribe el correo con el que te registraste"
                    android:textColor="@color/gris"
                    android:textSize="13sp"
                    android:layout_marginBottom="18dp" />

                <EditText
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_principal"
                    android:id="@+id/edtCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_campo"
                    android:hint="Correo"
                    android:inputType="textEmailAddress"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp" />

                <Button
                    android:id="@+id/btnBuscarCuenta"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_boton"
                    android:text="Continuar"
                    android:textColor="@color/blanco"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- PASO 2: responder la pregunta de seguridad -->
            <LinearLayout
                android:id="@+id/panelPaso2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paso 2: pregunta de seguridad"
                    android:textColor="@color/negro"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:id="@+id/txtPregunta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_aviso"
                    android:padding="14dp"
                    android:text="Pregunta"
                    android:textColor="@color/naranja_oscuro"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="14dp" />

                <EditText
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_principal"
                    android:id="@+id/edtRespuesta"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_campo"
                    android:hint="Tu respuesta"
                    android:inputType="text"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp" />

                <Button
                    android:id="@+id/btnVerificar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_boton"
                    android:text="Verificar respuesta"
                    android:textColor="@color/blanco"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- PASO 3: definir la contrasena nueva -->
            <LinearLayout
                android:id="@+id/panelPaso3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paso 3: nueva contrasena"
                    android:textColor="@color/negro"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elige una contrasena de al menos 6 caracteres"
                    android:textColor="@color/gris"
                    android:textSize="13sp"
                    android:layout_marginBottom="18dp" />

                <EditText
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_principal"
                    android:id="@+id/edtNuevaClave"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_campo"
                    android:hint="Nueva contrasena"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="12dp" />

                <EditText
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_principal"
                    android:id="@+id/edtConfirmarClave"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_campo"
                    android:hint="Confirmar contrasena"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp" />

                <Button
                    android:id="@+id/btnGuardarClave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_boton"
                    android:text="Guardar contrasena"
                    android:textColor="@color/blanco"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
