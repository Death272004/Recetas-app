<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/naranja"
            android:padding="14dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnVolver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textColor="@color/naranja"
                android:backgroundTint="@color/blanco"
                android:textSize="18sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:id="@+id/txtTituloPantalla"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nueva receta"
                android:textColor="@color/blanco"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <ImageView
                android:id="@+id/imgReceta"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center_horizontal"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_imagen_receta"
                android:src="@drawable/ic_receta"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnAdjuntarImagen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_boton_oscuro"
                android:text="Adjuntar imagen"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Sugerido: formato JPG, cuadrada (1:1), 240x240"
                android:textColor="@color/gris"
                android:textSize="12sp"
                android:layout_marginBottom="18dp" />

            <EditText
                android:id="@+id/edtTitulo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Titulo de la receta"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtIngredientes"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Ingredientes (separados por coma)"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtTiempo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Tiempo en minutos"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtCosto"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Costo estimado (B/.)"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtPasos"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_campo"
                android:gravity="top"
                android:hint="Pasos de preparacion"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtVideoUrl"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Link de YouTube (opcional)"
                android:inputType="textUri"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_boton"
                android:text="Guardar receta"
                android:textColor="@color/blanco"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
