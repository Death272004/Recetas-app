<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_tarjeta"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre usuario"
                android:textColor="@color/negro"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtReceta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="En: Titulo receta"
                android:textColor="@color/naranja"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtEstadoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aprobado"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtTexto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Texto del comentario..."
        android:textColor="@color/negro"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:maxLines="3"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/txtFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hace 2 horas"
        android:textColor="@color/gris"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnAprobar"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Aprobar"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/verde"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnOcultar"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Ocultar"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/amarillo"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Eliminar"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/rojo" />
    </LinearLayout>
</LinearLayout>
