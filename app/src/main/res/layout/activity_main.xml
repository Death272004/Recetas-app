<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Barra superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/naranja"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgFotoPerfil"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/foto_perfil_leo"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtSaludo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hola"
                android:textColor="@color/blanco"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Que hay en mi nevera?"
                android:textColor="@color/blanco"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSalir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Salir"
            android:textSize="12sp"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Seccion de busqueda -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Busca recetas con tus ingredientes"
                android:textColor="@color/negro"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa los ingredientes que tienes (separados por coma)"
                android:textColor="@color/gris"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtIngredientes"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Ej. pollo, arroz, huevo"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnBuscar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_boton"
                android:text="Buscar recetas"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnBuscarYouTube"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_boton_oscuro"
                android:text="▶  Buscar videos en YouTube"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <!-- Seccion de recetas recomendadas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recetas recomendadas de bajo presupuesto"
                android:textColor="@color/negro"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSugeridas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </ScrollView>

    <!-- Barra de navegacion inferior: Home | Feed | Favoritos | Otros -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/blanco"
        android:weightSum="4">

        <Button
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Home"
            android:textSize="11sp"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco" />

        <Button
            android:id="@+id/navFeed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Feed"
            android:textSize="11sp"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco" />

        <Button
            android:id="@+id/navFavoritos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Favoritos"
            android:textSize="11sp"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco" />

        <Button
            android:id="@+id/navOtros"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Otros"
            android:textSize="11sp"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco" />
    </LinearLayout>
</LinearLayout>
