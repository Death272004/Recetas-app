<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_tarjeta"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titulo de receta"
                android:textColor="@color/negro"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAutor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Por: Usuario"
                android:textColor="@color/gris"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtBadgeReportada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_rojo"
                android:text="Reportada"
                android:textColor="@color/rojo"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/txtBadgeOculta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_gris"
                android:text="Oculta"
                android:textColor="@color/gris"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/txtBadgeDestacada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_naranja"
                android:text="Destacada"
                android:textColor="@color/naranja"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txtMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="5 ingredientes · 20 min · B/. 2.50"
        android:textColor="@color/gris"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnDestacar"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Destacar"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/naranja"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnOcultar"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Ocultar"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/gris"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnQuitarReporte"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Quitar reporte"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/verde"
            android:visibility="gone"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Eliminar"
            android:textSize="11sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/rojo" />
    </LinearLayout>
</LinearLayout>
