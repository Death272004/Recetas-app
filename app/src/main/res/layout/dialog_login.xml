<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_tarjeta"
    android:padding="24dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="@string/app_name" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Inicia sesion para continuar"
        android:textColor="@color/negro"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/txtMensaje"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Entra a tu cuenta para ver esta receta"
        android:textColor="@color/gris"
        android:textSize="13sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="18dp" />

    <EditText
        android:id="@+id/edtCorreo"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_campo"
        android:hint="Correo"
        android:inputType="textEmailAddress"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/edtClave"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_campo"
        android:hint="Contrasena"
        android:inputType="textPassword"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnEntrar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_boton"
        android:text="Entrar y ver receta"
        android:textColor="@color/blanco"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtCrearCuenta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="No tienes cuenta? Registrate"
        android:textColor="@color/naranja"
        android:textStyle="bold"
        android:textSize="13sp"
        android:padding="12dp" />

    <TextView
        android:id="@+id/txtOlvide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="¿Olvidaste tu contrasena?"
        android:textColor="@color/gris"
        android:textSize="12sp"
        android:paddingBottom="4dp" />
</LinearLayout>
