<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/naranja"
            android:padding="14dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnVolver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textColor="@color/naranja"
                android:backgroundTint="@color/blanco"
                android:textSize="18sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Receta"
                android:textColor="@color/blanco"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiempo y costo"
                android:textColor="@color/verde"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingredientes"
                android:textColor="@color/negro"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtIngredientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lista de ingredientes"
                android:textColor="@color/negro"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preparacion"
                android:textColor="@color/negro"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPasos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pasos"
                android:textColor="@color/gris"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video tutorial"
                android:textColor="@color/negro"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtVideoNoDisponible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Video no disponible para esta receta"
                android:textColor="@color/gris"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnVerVideo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_boton_oscuro"
                android:text="▶  Ver tutorial en YouTube"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnBuscarYouTube"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_boton_oscuro"
                android:text="🔍  Buscar tutorial en YouTube"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnFavorito"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_boton"
                android:text="Agregar a favoritos"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnCompras"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_boton_oscuro"
                android:text="Anadir lo que me falta a compras"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnReportar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="@color/gris"
                android:text="Reportar receta"
                android:textColor="@color/blanco"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
