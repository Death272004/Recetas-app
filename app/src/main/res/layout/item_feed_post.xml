<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_tarjeta"
    android:layout_marginBottom="14dp">

    <!-- Encabezado: avatar + usuario + tiempo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtAvatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="?" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/txtUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuario"
                android:textColor="@color/negro"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTimeAgo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hace un momento"
                android:textColor="@color/gris"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Titulo de la receta -->
    <TextView
        android:id="@+id/txtRecipeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:text="Nombre de la receta"
        android:textColor="@color/negro"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Imagen del plato -->
    <ImageView
        android:id="@+id/imgPost"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_receta"
        android:contentDescription="Imagen de la receta" />

    <!-- Botones de interaccion -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btnLike"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:text="♥  0"
            android:textColor="@color/naranja"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnComentar"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:text="💬  Comentar"
            android:textColor="@color/gris"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnCompartir"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:text="↗  Compartir"
            android:textColor="@color/gris"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
