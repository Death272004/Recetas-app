<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/naranja"
        android:padding="14dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹"
            android:textColor="@color/naranja"
            android:backgroundTint="@color/blanco"
            android:textSize="18sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Registro"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crea tu cuenta"
                android:textColor="@color/negro"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp" />

            <EditText
                android:id="@+id/edtNombre"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Nombre de usuario"
                android:inputType="textPersonName"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtCorreo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Correo"
                android:inputType="textEmailAddress"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtClave"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Contrasena (minimo 6 caracteres)"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtConfirmar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Confirmar contrasena"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="18dp" />

            <!-- Pregunta de seguridad: se usa para recuperar la contrasena -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pregunta de seguridad"
                android:textColor="@color/negro"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="La usaras si olvidas tu contrasena"
                android:textColor="@color/gris"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerPregunta"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtRespuesta"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:hint="Tu respuesta"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_boton"
                android:text="Registrarme"
                android:textColor="@color/blanco"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtIrLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Ya tengo cuenta. Iniciar sesion"
                android:textColor="@color/naranja"
                android:textStyle="bold"
                android:padding="16dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
